# Django
SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=your-service.onrender.com,localhost

# Supabase PostgreSQL
# Найди в Supabase → Project Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres.USER:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?sslmode=require&options=-csearch_path%3Dml

# Supabase Storage
# Найди в Supabase → Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGci...  # service_role key (не anon!)
SUPABASE_BUCKET=ml-models

# API Key — любая случайная строка, одинаковая в обоих сервисах
ML_API_KEY=super-secret-key-shared-with-main-backend

# API guardrails
ML_MAX_PREDICT_BATCH=1000
ML_EXCLUDED_ROLES=HR,ADMIN,COMMISSION

# Automatic bootstrap on container startup (good for Render free tier)
ML_BOOTSTRAP_ON_START=true
ML_BOOTSTRAP_LOAD_DATASET=true
ML_BOOTSTRAP_TRAIN=true
ML_BOOTSTRAP_MODEL_TYPE=random_forest
ML_BOOTSTRAP_STRICT=false

# Main backend ML client timeouts (seconds)
ML_CONNECT_TIMEOUT=2
ML_READ_TIMEOUT=10
